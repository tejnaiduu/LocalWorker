{
  "buildCommand": "npm --prefix=./frontend install && npm --prefix=./frontend run build",
  "outputDirectory": "frontend/dist",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://localworker.onrender.com/api/$1"
    },
    {
      "src": "^/(?!api).*",
      "dest": "/index.html"
    }
  ],
  "functions": {
    "frontend/dist/**": {
      "memory": 1024,
      "maxDuration": 60
    }
  }
}
